<Window x:Class="DoAnCSharp_WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Quản Lý Sinh Viên"
        WindowState="Maximized">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Menu Grid.Row="0" Margin="0,0,0,10">
            <MenuItem Header="File">
                <MenuItem x:Name="saveFileMenu" Header="Save"/>
                <MenuItem x:Name="openFileMenu" Header="Open"/>
                <MenuItem Header="Export">
                    <MenuItem x:Name="exportPdfMenu" Header=".pdf"/>
                </MenuItem>
                <MenuItem x:Name="closeFileMenu" Header="Close"/>
            </MenuItem>
            <MenuItem Header="SQL">
                <MenuItem x:Name="openSQLMenu" Header="Open SQL"/>
                <MenuItem x:Name="loadSQLMenu" Header="Load Data"/>
                <MenuItem x:Name="closeSQLMenu" Header="Close SQL"/>
            </MenuItem>
            <MenuItem x:Name="aboutUsMenu" Header="About Us"/>
        </Menu>

        <GroupBox Header="Tìm kiếm sinh viên" Grid.Row="1" Margin="0,0,0,10" Padding="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Label Content="Quê quán:" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,5,0"/>
                <ComboBox x:Name="comboBoxQueQuan" Grid.Column="1" Margin="0,0,20,0" VerticalAlignment="Center" Height="30"/>
                <Label Content="Mã sinh viên:" Grid.Column="2" VerticalAlignment="Center" Margin="0,0,5,0"/>
                <TextBox x:Name="textBoxMaSinhVien" Grid.Column="3" Margin="0,0,20,0" VerticalContentAlignment="Center" Height="30"/>
                <Button x:Name="buttonTim" Content="Tìm kiếm" Grid.Column="4" Width="90" Height="30" Margin="0,0,10,0"/>
                <Button x:Name="buttonHuyTim" Content="Hủy tìm" Grid.Column="5" Width="90" Height="30"/>
            </Grid>
        </GroupBox>

        <GroupBox Header="Danh sách sinh viên" Grid.Row="2" Margin="0,0,0,10">
            <DataGrid x:Name="table" AutoGenerateColumns="False" SelectionChanged="table_SelectionChanged" IsReadOnly="True" SelectionMode="Single">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Mã Sinh Viên" Binding="{Binding MaSinhVien}" Width="180"/>
                    <DataGridTextColumn Header="Họ và Tên" Binding="{Binding TenSinhVien}" Width="280"/>
                    <DataGridTextColumn Header="Giới Tính" Binding="{Binding GioiTinhText}" Width="120"/>
                    <DataGridTextColumn Header="Quê Quán" Binding="{Binding QueQuan.TenTinh}" Width="180"/>
                    <DataGridTextColumn Header="Ngày Sinh" Binding="{Binding NgaySinh, StringFormat=dd/MM/yyyy}" Width="150"/>
                    <DataGridTextColumn Header="Điểm TX1" Binding="{Binding DiemThuongXuyen1}" Width="120"/>
                    <DataGridTextColumn Header="Điểm TX2" Binding="{Binding DiemThuongXuyen2}" Width="120"/>
                    <DataGridTextColumn Header="Điểm TX3" Binding="{Binding DiemThuongXuyen3}" Width="120"/>
                    <DataGridTextColumn Header="Điểm GK" Binding="{Binding DiemGiuaKi}" Width="120"/>
                    <DataGridTextColumn Header="Điểm CK" Binding="{Binding DiemCuoiKi}" Width="120"/>
                </DataGrid.Columns>
            </DataGrid>
        </GroupBox>

        <TextBlock Grid.Row="3" Text="Thông tin chi tiết sinh viên" FontStyle="Italic" FontWeight="Bold" FontSize="14" Margin="5,0,0,5"/>
        <Border Grid.Row="4" BorderBrush="LightGray" BorderThickness="1" CornerRadius="3" Padding="15,10" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="40"/>

                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Label Content="Mã sinh viên:" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Margin="0,6"/>
                <TextBox x:Name="textBoxMaSinhVienThem" Grid.Row="0" Grid.Column="1" Height="28" Margin="5,6" VerticalContentAlignment="Center"/>

                <Label Content="Họ và tên:" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Margin="0,6"/>
                <TextBox x:Name="textBoxHoVaTen" Grid.Row="1" Grid.Column="1" Height="28" Margin="5,6" VerticalContentAlignment="Center"/>

                <Label Content="Quê quán:" Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Margin="0,6"/>
                <ComboBox x:Name="comboBoxQueQuanThem" Grid.Row="2" Grid.Column="1" Height="28" Margin="5,6" VerticalContentAlignment="Center"/>

                <Label Content="Ngày sinh (d/m/y):" Grid.Row="3" Grid.Column="0" VerticalAlignment="Center" Margin="0,6"/>
                <Grid Grid.Row="3" Grid.Column="1" Margin="5,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="1.5*"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="textBoxNgay" Grid.Column="0" Height="28" VerticalContentAlignment="Center" HorizontalContentAlignment="Center"/>
                    <TextBlock Text="/" Grid.Column="1" VerticalAlignment="Center" FontSize="16" Margin="6,0"/>
                    <TextBox x:Name="textBoxThang" Grid.Column="2" Height="28" VerticalContentAlignment="Center" HorizontalContentAlignment="Center"/>
                    <TextBlock Text="/" Grid.Column="3" VerticalAlignment="Center" FontSize="16" Margin="6,0"/>
                    <TextBox x:Name="textBoxNam" Grid.Column="4" Height="28" VerticalContentAlignment="Center" HorizontalContentAlignment="Center"/>
                </Grid>


                <Label Content="Giới tính:" Grid.Row="0" Grid.Column="3" VerticalAlignment="Center" Margin="0,6"/>
                <StackPanel Orientation="Horizontal" Grid.Row="0" Grid.Column="4" VerticalAlignment="Center" Margin="5,6">
                    <RadioButton x:Name="radioButtonNam" Content="Nam" Margin="5,0,20,0" VerticalAlignment="Center"/>
                    <RadioButton x:Name="radioButtonNu" Content="Nữ" VerticalAlignment="Center"/>
                </StackPanel>

                <Label Content="Điểm số:" Grid.Row="1" Grid.Column="3" VerticalAlignment="Top" Margin="0,6"/>

                <Grid Grid.Row="1" Grid.RowSpan="3" Grid.Column="4" Margin="5,0,5,5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="TX1:" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Margin="0,6"/>
                    <TextBox x:Name="textBoxDiemThuongXuyen1" Grid.Row="0" Grid.Column="1" Height="28" Margin="5,6" VerticalContentAlignment="Center" HorizontalContentAlignment="Center"/>

                    <TextBlock Text="TX2:" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Margin="0,6"/>
                    <TextBox x:Name="textBoxDiemThuongXuyen2" Grid.Row="1" Grid.Column="1" Height="28" Margin="5,6" VerticalContentAlignment="Center" HorizontalContentAlignment="Center"/>

                    <TextBlock Text="TX3:" Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Margin="0,6"/>
                    <TextBox x:Name="textBoxDiemThuongXuyen3" Grid.Row="2" Grid.Column="1" Height="28" Margin="5,6" VerticalContentAlignment="Center" HorizontalContentAlignment="Center"/>

                    <TextBlock Text="Giữa kì:" Grid.Row="0" Grid.Column="3" VerticalAlignment="Center" Margin="0,6"/>
                    <TextBox x:Name="textBoxDiemGiuaKi" Grid.Row="0" Grid.Column="4" Height="28" Margin="5,6" VerticalContentAlignment="Center" HorizontalContentAlignment="Center"/>

                    <TextBlock Text="Cuối kì:" Grid.Row="1" Grid.Column="3" VerticalAlignment="Center" Margin="0,6"/>
                    <TextBox x:Name="textBoxDiemCuoiKi" Grid.Row="1" Grid.Column="4" Height="28" Margin="5,6" VerticalContentAlignment="Center" HorizontalContentAlignment="Center"/>
                </Grid>
            </Grid>
        </Border>

        <UniformGrid Grid.Row="5" Columns="5" Rows="1" HorizontalAlignment="Center" Margin="0,5,0,0">
            <Button x:Name="buttonThem" Content="Thêm" Width="120" Height="35" Margin="10,0"/>
            <Button x:Name="buttonChinhSua" Content="Chỉnh sửa" Width="120" Height="35" Margin="10,0"/>
            <Button x:Name="buttonXoa" Content="Xóa" Width="120" Height="35" Margin="10,0"/>
            <Button x:Name="buttonLuu" Content="Lưu" Width="120" Height="35" Margin="10,0"/>
            <Button x:Name="buttonHuyBo" Content="Hủy bỏ" Width="120" Height="35" Margin="10,0"/>
        </UniformGrid>
    </Grid>
</Window>