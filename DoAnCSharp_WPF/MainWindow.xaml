<Window x:Class="DoAnCSharp_WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Quản Lý Sinh Viên - Phiên bản WPF" Height="850" Width="1050" WindowStartupLocation="CenterScreen">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Menu Grid.Row="0" Margin="0,0,0,10">
            <MenuItem Header="File">
                <MenuItem x:Name="saveFileMenu" Header="Save"/>
                <MenuItem x:Name="openFileMenu" Header="Open"/>
                <MenuItem x:Name="closeFileMenu" Header="Close"/>
            </MenuItem>
            <MenuItem Header="SQL">
                <MenuItem x:Name="openSQLMenu" Header="Open SQL"/>
                <MenuItem x:Name="loadSQLMenu" Header="Load Data"/>
                <MenuItem x:Name="closeSQLMenu" Header="Close SQL"/>
            </MenuItem>
            <MenuItem x:Name="aboutUsMenu" Header="About Us"/>
        </Menu>

        <GroupBox Header="Tìm kiếm sinh viên" Grid.Row="1" Margin="0,0,0,10" Padding="10">
            <StackPanel Orientation="Horizontal">
                <Label Content="Quê quán:" VerticalAlignment="Center"/>
                <ComboBox x:Name="comboBoxQueQuan" Width="180" Margin="5,0,20,0" VerticalAlignment="Center"/>

                <Label Content="Mã sinh viên:" VerticalAlignment="Center"/>
                <TextBox x:Name="textBoxMaSinhVien" Width="150" Margin="5,0,20,0" VerticalContentAlignment="Center" Height="30"/>

                <Button x:Name="buttonTim" Content="Tìm kiếm" Width="90" Height="30" Margin="0,0,10,0"/>
                <Button x:Name="buttonHuyTim" Content="Hủy tìm" Width="90" Height="30"/>
            </StackPanel>
        </GroupBox>

        <GroupBox Header="Danh sách sinh viên" Grid.Row="2" Margin="0,0,0,10">
            <DataGrid x:Name="table" AutoGenerateColumns="False" IsReadOnly="True" SelectionMode="Single" VerticalAlignment="Stretch">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Mã Sinh Viên" Binding="{Binding MaSinhVien}" Width="120"/>
                    <DataGridTextColumn Header="Họ và Tên" Binding="{Binding TenSinhVien}" Width="200"/>
                    <DataGridTextColumn Header="Giới Tính" Binding="{Binding GioiTinhText}" Width="80"/>
                    <DataGridTextColumn Header="Quê Quán" Binding="{Binding QueQuan.TenTinh}" Width="120"/>
                    <DataGridTextColumn Header="Ngày Sinh" Binding="{Binding NgaySinh, StringFormat=dd/MM/yyyy}" Width="110"/>
                    <DataGridTextColumn Header="Điểm TX1" Binding="{Binding DiemThuongXuyen1}" Width="80"/>
                    <DataGridTextColumn Header="Điểm TX2" Binding="{Binding DiemThuongXuyen2}" Width="80"/>
                    <DataGridTextColumn Header="Điểm TX3" Binding="{Binding DiemThuongXuyen3}" Width="80"/>
                    <DataGridTextColumn Header="Điểm GK" Binding="{Binding DiemGiuaKi}" Width="80"/>
                    <DataGridTextColumn Header="Điểm CK" Binding="{Binding DiemCuoiKi}" Width="80"/>
                </DataGrid.Columns>
            </DataGrid>
        </GroupBox>

        <TextBlock Grid.Row="3" Text="Thông tin chi tiết sinh viên" FontStyle="Italic" FontWeight="Bold" FontSize="14" Margin="5,0,0,5"/>

        <Border Grid.Row="4" BorderBrush="LightGray" BorderThickness="1" CornerRadius="3" Padding="10" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="110"/>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="130"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Label Content="Mã sinh viên:" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center"/>
                <TextBox x:Name="textBoxMaSinhVienThem" Grid.Row="0" Grid.Column="1" Margin="5" Height="28" VerticalContentAlignment="Center"/>

                <Label Content="Giới tính:" Grid.Row="0" Grid.Column="2" VerticalAlignment="Center" Margin="20,0,0,0"/>
                <StackPanel Orientation="Horizontal" Grid.Row="0" Grid.Column="3" VerticalAlignment="Center">
                    <RadioButton x:Name="radioButtonNam" Content="Nam" Margin="5,0,20,0"/>
                    <RadioButton x:Name="radioButtonNu" Content="Nữ" Margin="5,0,0,0"/>
                </StackPanel>

                <Label Content="Họ và tên:" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center"/>
                <TextBox x:Name="textBoxHoVaTen" Grid.Row="1" Grid.Column="1" Margin="5" Height="28" VerticalContentAlignment="Center"/>

                <Label Content="Ngày sinh (d/m/y):" Grid.Row="1" Grid.Column="2" VerticalAlignment="Center" Margin="20,0,0,0"/>
                <StackPanel Orientation="Horizontal" Grid.Row="1" Grid.Column="3" VerticalAlignment="Center">
                    <TextBox x:Name="textBoxNgay" Width="40" Height="28" Margin="5" VerticalContentAlignment="Center" HorizontalContentAlignment="Center"/>
                    <TextBlock Text="/" VerticalAlignment="Center" FontSize="16"/>
                    <TextBox x:Name="textBoxThang" Width="40" Height="28" Margin="5" VerticalContentAlignment="Center" HorizontalContentAlignment="Center"/>
                    <TextBlock Text="/" VerticalAlignment="Center" FontSize="16"/>
                    <TextBox x:Name="textBoxNam" Width="60" Height="28" Margin="5" VerticalContentAlignment="Center" HorizontalContentAlignment="Center"/>
                </StackPanel>

                <Label Content="Quê quán:" Grid.Row="2" Grid.Column="0" VerticalAlignment="Center"/>
                <ComboBox x:Name="comboBoxQueQuanThem" Grid.Row="2" Grid.Column="1" Margin="5" Height="28"/>

                <Label Content="Điểm TX (1/2/3):" Grid.Row="2" Grid.Column="2" VerticalAlignment="Center" Margin="20,0,0,0"/>
                <StackPanel Orientation="Horizontal" Grid.Row="2" Grid.Column="3" VerticalAlignment="Center">
                    <TextBox x:Name="textBoxDiemThuongXuyen1" Width="45" Height="28" Margin="5" VerticalContentAlignment="Center" HorizontalContentAlignment="Center"/>
                    <TextBox x:Name="textBoxDiemThuongXuyen2" Width="45" Height="28" Margin="5" VerticalContentAlignment="Center" HorizontalContentAlignment="Center"/>
                    <TextBox x:Name="textBoxDiemThuongXuyen3" Width="45" Height="28" Margin="5" VerticalContentAlignment="Center" HorizontalContentAlignment="Center"/>
                </StackPanel>

                <Label Content="Điểm GK &amp; CK:" Grid.Row="3" Grid.Column="2" VerticalAlignment="Center" Margin="20,0,0,0"/>
                <StackPanel Orientation="Horizontal" Grid.Row="3" Grid.Column="3" VerticalAlignment="Center">
                    <TextBox x:Name="textBoxDiemGiuaKi" Width="50" Height="28" Margin="5" VerticalContentAlignment="Center" HorizontalContentAlignment="Center"/>
                    <Label Content="Cuối kì:" VerticalAlignment="Center" Margin="10,0,0,0"/>
                    <TextBox x:Name="textBoxDiemCuoiKi" Width="50" Height="28" Margin="5" VerticalContentAlignment="Center" HorizontalContentAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
            <Button x:Name="buttonThem" Content="Thêm" Width="110" Height="38" Margin="10,0"/>
            <Button x:Name="buttonChinhSua" Content="Chỉnh sửa" Width="110" Height="38" Margin="10,0"/>
            <Button x:Name="buttonXoa" Content="Xóa" Width="110" Height="38" Margin="10,0"/>
            <Button x:Name="buttonLuu" Content="Lưu" Width="110" Height="38" Margin="10,0"/>
            <Button x:Name="buttonHuyBo" Content="Hủy bỏ" Width="110" Height="38" Margin="10,0"/>
        </StackPanel>
    </Grid>
</Window>